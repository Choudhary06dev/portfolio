{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict Mode and Path Resolution */
    "strict": true,
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],
      "@/components": ["./src/components"],
      "@/components/*": ["./src/components/*"],
      "@/sections": ["./src/sections"],
      "@/sections/*": ["./src/sections/*"],
      "@/pages": ["./src/pages"],
      "@/pages/*": ["./src/pages/*"],
      "@/hooks": ["./src/hooks"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/utils": ["./src/utils"],
      "@/utils/*": ["./src/utils/*"],
      "@/styles": ["./src/styles"],
      "@/styles/*": ["./src/styles/*"],
      "@/assets": ["./src/assets"],
      "@/assets/*": ["./src/assets/*"],
      "@/services": ["./src/services"],
      "@/services/*": ["./src/services/*"],
      "@/config": ["./src/config"],
      "@/config/*": ["./src/config/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "src/**/*.ts", "src/**/*.tsx"]
}
